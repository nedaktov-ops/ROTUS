{
  "name": "rotus",
  "version": "1.0.0",
  "description": "ROTUS - The Rotten Brain of POTUS. A parody app collecting verified quotes from Donald Trump.",
  "main": "index.js",
  "scripts": {
    "start": "cd webapp && node server.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --testTimeout=10000",
    "test:watch": "jest --watch",
    "bundle": "node generate-bundle.js",
    "cap:add:ios": "capacitor add ios",
    "cap:add:android": "capacitor add android",
    "cap:sync": "capacitor sync",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "trump",
    "quotes",
    "fact-check",
    "parody",
    "mobile",
    "web"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "jest": "^30.3.0",
    "node-fetch": "^3.3.2",
    "supertest": "^7.2.2",
    "vite": "^5.4.0"
  },
  "directories": {
    "doc": "docs"
  }
}
